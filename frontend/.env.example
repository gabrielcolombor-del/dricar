# URL da Planilha do Google Sheets (exportada como CSV / publicada na Web)
# Para obter este link, na sua Planilha Google clique em: Arquivo -> Compartilhar -> Publicar na web.
# Selecione apenas a página com os dados (ex: "Veículos" ou "Página1") e mude o formato para "Valores separados por vírgula (.csv)".
NEXT_PUBLIC_SHEET_CSV_URL=""

# Senha de acesso ao painel administrativo (escolha uma senha segura)
ADMIN_PASSWORD=""

# URL do Web App gerado no Google Apps Script para permitir inserções/edições
GOOGLE_SCRIPT_API_URL=""

