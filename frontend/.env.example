# Supabase Connection URL (Pooler - porta 6543 para produção com PgBouncer)
DATABASE_URL="postgresql://postgres:[SENHA_BANCO]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexão direta com Supabase para executar migrações e comandos CLI (porta 5432)
DIRECT_URL="postgresql://postgres:[SENHA_BANCO]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Supabase Storage & SDK
NEXT_PUBLIC_SUPABASE_URL="https://[SEU_ID_PROJETO].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUA_ANON_KEY_PUBLICA]"
SUPABASE_SERVICE_ROLE_KEY="[SUA_SERVICE_ROLE_KEY_PRIVADA]"

# NextAuth.js (Autenticação)
# NEXTAUTH_SECRET: Use um gerador de chave ou execute `openssl rand -base64 32` no terminal
NEXTAUTH_SECRET="[CHAVE_CRIPTOGRAFIA_SESSION]"
NEXTAUTH_URL="http://localhost:3000"
